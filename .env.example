# Copie para `.env` e ajuste. O binario carrega `.env` automaticamente em desenvolvimento.
# `cargo run` na raiz do projeto encontra o ficheiro.

PORTA=3000
DIRETORIO_ARMAZENAMENTO=./armazenamento
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/file_storage

# Chave para rotas /api/v1/admin/* (criar/listar/apagar projetos). Troque em producao.
API_KEY_ADMIN=admin-chave-local-trocar

# Limite maximo por upload em bytes (default no codigo: 100 MiB se omitido)
# TAMANHO_MAXIMO_ARQUIVO_BYTES=104857600

# Opcional: URL base nas respostas de upload (se vazio, usa http://localhost:PORTA)
# BASE_URL=http://localhost:3000
